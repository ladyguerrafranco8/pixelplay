# ============================================================
# PixelPlay — credenciales del PANEL ADMIN (las elige Lady)
# ============================================================
# 1. Copiá este archivo a  .env.local   (que está en .gitignore → NUNCA se sube al repo)
# 2. Poné TU usuario (email) y TU clave. Elegí una clave fuerte.
# 3. En el setup, Claude lee este .env.local y crea el usuario en Supabase Auth.
#    La app que corre en el navegador NO lee este archivo — solo lo usa Claude
#    una vez, al conectar. Tu clave nunca queda en el repo ni en el sitio.
#
# Con estos datos vas a entrar a  /admin .
# ------------------------------------------------------------

# Tu usuario para entrar al panel. Podés usar tu correo real
# (ej: lady@gmail.com) o uno interno (ej: lady@pixelplay.local).
ADMIN_EMAIL=lady@pixelplay.local

# Tu clave del panel. CAMBIALA por una fuerte (no uses esta).
ADMIN_PASSWORD=cambia-esta-clave
